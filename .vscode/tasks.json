{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Slidev: dev server",
      "type": "shell",
      "command": "test -d node_modules || npm install && npm run dev",
      "windows": {
        "command": "if not exist node_modules npm install && npm run dev"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "focus": false
      },
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": ".*(ready in|Local:|localhost|127\\.0\\.0\\.1).*"
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
